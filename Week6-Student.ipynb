    "# Cell 2: Variogram Analysis - Jupyter Notebook 版本\n",
    "# 直接複製到 Jupyter Notebook Cell 中執行\n",
    "\n",
    "# 安裝必要套件\n",
    "try:\n",
    "    import pykrige\n",
    "    from pykrige.ok import OrdinaryKriging\n",
    "    print(\"pykrige 已經可用\")\n",
