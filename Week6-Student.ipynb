    "#!/usr/bin/env python3\n",
    "# -*- coding: utf-8 -*-\n",
    "\"\"\"\n",
    "Week 6 Cell 2: Variogram Analysis & Kriging Basics (Simplified Version)\n",
    "Spatial Prediction Shootout - Variogram Analysis Functions\n",
