    "\n",
    "# OK = OrdinaryKriging(x, y, z_log, variogram_model='spherical',\n",
    "#                       verbose=False, enable_plotting=True, nlags=15,\n",
    "#                       variogram_parameters={'sill': initial_sill,\n",
    "#                                             'range': initial_range,\n",
    "#                                             'nugget': initial_nugget})\n",
