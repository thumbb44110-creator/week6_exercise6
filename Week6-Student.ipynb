    "    print(\"-\" * 40)\n",
    "    \n",
    "    for val in sample_values:\n",
    "        log_val = np.log1p(val)\n",
    "        back_val = np.expm1(log_val)\n",
    "        print(f\"{val:6.1f} → {log_val:8.3f} → {back_val:6.1f}\")\n",
    "    \n",
    "    print(\"\\n轉換特性:\")\n",
    "    print(\"  - 小值壓縮較少，大值壓縮較多\")\n",
    "    print(\"  - 保持數值順序關係\")\n",
    "    print(\"  - 避免負無窮大問題\")\n",
    "    print(\"  - 可完全還原原始值\")\n",
    "\n",
    "def main_analysis():\n",
